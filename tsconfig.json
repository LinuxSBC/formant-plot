{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "jquery", "jqueryui", "raphael", "tippy.js"],
    "paths": {}
  },
  "include": [
    "**/*.ts",
    "node_modules/@types/jquery/misc.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}